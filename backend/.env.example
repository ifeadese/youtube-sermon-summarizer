# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must NEVER be committed.
#
# Get a key from your personal Anthropic account at https://console.anthropic.com
# (this is the developer API — prepaid credits — NOT a Claude.ai Pro/Max subscription).
ANTHROPIC_API_KEY=your-key-here

# --- Deploy/runtime config (optional locally; set in the host dashboard in prod) ---

# Comma-separated frontend origins allowed by CORS. Defaults to the local dev
# servers if unset; set to your deployed frontend URL in production.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Residential proxy for transcript fetching. Required in production (YouTube
# blocks datacenter IPs); leave unset locally. Use EITHER the Webshare pair:
# WEBSHARE_PROXY_USERNAME=your-webshare-username
# WEBSHARE_PROXY_PASSWORD=your-webshare-password
# ...OR a generic proxy:
# PROXY_HTTP_URL=http://user:pass@proxy.example.com:8080
# PROXY_HTTPS_URL=https://user:pass@proxy.example.com:8080
